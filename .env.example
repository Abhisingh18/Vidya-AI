# Copy this file to .env.local and fill in real values.

# NextAuth — the URL your app is served from + a random secret for JWT signing.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Google OAuth — optional, leave as-is to fall back to the guest-login flow.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenRouter — used by /api/generate to call free LLMs for new video generation.
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Optional: Prisma database URL. Defaults to local SQLite (./prisma/dev.db).
# For production deploys (Render / Postgres), set this to your DB connection string.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
